{
  "name": "rapidrest.io",
  "version": "0.0.0",
  "description": "The RapidREST documentation and marketing website, built with Docusaurus.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rapidrest/rapidrest.io.git"
  },
  "license": "MIT",
  "private": true,
  "scripts": {
    "docusaurus": "docusaurus",
    "generate-typedoc": "docusaurus generate-typedoc",
    "start": "yarn generate-typedoc && docusaurus start",
    "build": "yarn generate-typedoc && docusaurus build",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "typecheck": "tsc"
  },
  "dependencies": {
    "@docusaurus/core": "^3.10.2",
    "@docusaurus/faster": "^3.10.2",
    "@docusaurus/preset-classic": "^3.10.2",
    "@mdx-js/react": "^3.0.0",
    "clsx": "^2.0.0",
    "prism-react-renderer": "^2.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "^3.10.2",
    "@docusaurus/tsconfig": "^3.10.2",
    "@docusaurus/types": "^3.10.2",
    "@types/react": "^19.0.0",
    "docusaurus-plugin-typedoc": "^1.4.2",
    "typedoc": "^0.28.20",
    "typedoc-docusaurus-theme": "^1.4.0",
    "typedoc-plugin-markdown": "^4.9.0",
    "typescript": "~6.0.2"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  },
  "engines": {
    "node": ">=24.0"
  },
  "packageManager": "yarn@4.5.3"
}
